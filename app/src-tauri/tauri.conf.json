{
  "productName": "Rustok",
  "version": "0.1.5",
  "identifier": "com.rustok.app",
  "build": {
    "beforeDevCommand": "cd src && trunk serve --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd src && trunk build --release",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "Rustok",
        "width": 420,
        "height": 720,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
